# Copy to .env and fill GROQ_API_KEY. Everything else has working defaults.

# LLM for query rewriting + answer generation (OpenAI-compatible).
# Default = Groq (reuse the Basic RAG key). To use OpenRouter instead, set:
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=deepseek/deepseek-chat
#   LLM_API_KEY=sk-or-...
GROQ_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b

# Embeddings / reranker (Hugging Face model ids). Downloaded on first use.
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_USE_FP16=1

# Qdrant: embedded file store by default (no Docker). For a server set QDRANT_URL.
QDRANT_PATH=./qdrant_data
# QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vwo_test_cases

# Pipeline tunables
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_N_HYBRID=20
TOP_K_RERANK=4
RRF_K=60
REWRITE_ENABLED=1
INGEST_BATCH=16

PORT=5050
