# OpenAI — used for query rewriting and answer generation
OPENAI_API_KEY=

# Query rewriting model (cheap/fast — spec only pins gpt-4o for generation)
OPENAI_REWRITE_MODEL=gpt-4o-mini

# Generation model (per spec)
OPENAI_GENERATION_MODEL=gpt-4o

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vwo_test_cases

# BGE models (BAAI, via FlagEmbedding)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_DEVICE=cuda

# Retrieval tuning
TOP_K_PREFETCH=50
TOP_K_RETRIEVE=20
TOP_K_RERANK=8

# CORS / frontend dev
FRONTEND_ORIGIN=http://localhost:5173
